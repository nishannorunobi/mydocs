# ── Plane version ─────────────────────────────────────────────────────────────
PLANE_VERSION=latest

# ── App ───────────────────────────────────────────────────────────────────────
# URL your browser uses to reach Plane (no trailing slash)
WEB_URL=http://localhost:8080
PLANE_PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:8080
DEBUG=0
DJANGO_SETTINGS_MODULE=plane.settings.production

# ── Secret key — CHANGE THIS before first run ─────────────────────────────────
SECRET_KEY=n3oYeZ1y-YzkhNrBjl0MqpHztQ22YaAw7oAMRWnBYc-pyeyYncLihtEhXOUy0iJqAyg

# ── Database (external — mypostgresql_db-container on my_docker_network) ───────────
POSTGRES_USER=docs_user
POSTGRES_PASSWORD=docs_pass
POSTGRES_DB=mydocsdb
POSTGRES_HOST=mypostgresql_db-container
POSTGRES_PORT=5432
DATABASE_URL=postgresql://docs_user:docs_pass@mypostgresql_db-container:5432/mydocsdb

# ── Redis (external — mycache-redis container on mycache_mycache-net) ────────
REDIS_HOST=mycache-redis
REDIS_PORT=6379
REDIS_URL=redis://:cache_pass@mycache-redis:6379/0

# ── Object Storage (MinIO) ────────────────────────────────────────────────────
MINIO_ROOT_USER=plane-minio
MINIO_ROOT_PASSWORD=plane_minio_pass
AWS_ACCESS_KEY_ID=plane-minio
AWS_SECRET_ACCESS_KEY=plane_minio_pass
AWS_S3_ENDPOINT_URL=http://localhost:9000
AWS_S3_BUCKET_NAME=uploads
AWS_REGION=us-east-1
USE_MINIO=1
MINIO_ENDPOINT_SSL=0

# ── Email (optional — leave blank to skip) ───────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_PORT=587
EMAIL_USE_TLS=1
EMAIL_FROM=

# ── Auth ──────────────────────────────────────────────────────────────────────
ENABLE_SIGNUP=0
ENABLE_EMAIL_PASSWORD=1
ENABLE_MAGIC_LINK_LOGIN=0

# ── OAuth (leave blank to disable) ───────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_APP_NAME=
GITLAB_HOST=
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=

# ── OpenAI (optional — for AI features) ──────────────────────────────────────
OPENAI_API_KEY=
GPT_ENGINE=

# ── RabbitMQ (mychannels-rabbitmq — external broker) ──────────────────────────
AMQP_URL=amqp://admin:channels_pass@mychannels-rabbitmq:5672/
RABBITMQ_HOST=mychannels-rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=channels_pass
RABBITMQ_VHOST=/
